# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="TamilScholar Pro"
DEBUG=true
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tamilscholar:tamilscholar_secret@postgres:5432/tamilscholar_db
#DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/tamilscholar
POSTGRES_USER=tamilscholar
POSTGRES_PASSWORD=tamilscholar_secret
POSTGRES_DB=tamilscholar_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
PRIVATE_KEY_PATH=./keys/private.pem
PUBLIC_KEY_PATH=./keys/public.pem

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com
GROQ_API_KEY=your_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=mixtral-8x7b-32768

# Optional: Use OpenAI instead
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# LLM_PROVIDER=openai

# ── Pinecone ──────────────────────────────────────────────────────────────────
# Get from: https://app.pinecone.io
PINECONE_API_KEY=pcsk_3avPVV_AB981XCoJLgAdWNv9aEer2UsGQLYS8y1uPnVyZKMzjY5ymceVyk1cU2Ti8x9QhD
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=tamilscholar-scholarships

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# ── Admin ─────────────────────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@tamilscholar.gov.in
FIRST_ADMIN_PASSWORD=ChangeMe@123!

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://frontend:3000"]
